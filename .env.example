# ============================================================
# Wiki Brain — 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# ============================================================

# --- Wiki 路径 ---
WIKI_ROOT=/data
MCP_PORT=8764
MCP_HOST=0.0.0.0

# --- OpenViking ---
# 取消注释并填入实际值以启用语义搜索
# OPENVIKING_ENDPOINT=http://localhost:1933
# OPENVIKING_API_KEY=
# OPENVIKING_ACCOUNT=hermes
# OPENVIKING_USER=default
# OPENVIKING_BIN=/usr/local/bin/openviking

# --- LLM (dream_cycle / memory_to_wiki) ---
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_API_KEY=
DREAM_CYCLE_MODEL=glm-4-flash
MEMORY_TO_WIKI_MODEL=glm-4-flash

# --- Notion (wiki-to-notion) ---
# NOTION_API_KEY=
# WEBDAV_BASE_URL=
# WEBDAV_USER=
# WEBDAV_PASS=

# --- 备份 ---
# WIKI_SOURCE=./wiki
# WIKI_BACKUP_DIR=./backups
# MAX_BACKUPS=10
