# === MCP Server ===
MCP_PORT=8764
# MCP_API_KEY=***    # Leave empty to skip auth (recommended for LAN)

# === OpenViking (optional, for semantic search) ===
# OPENVIKING_ENDPOINT=http://localhost:1933
# OPENVIKING_API_KEY=***
# OPENVIKING_ACCOUNT=hermes
# OPENVIKING_USER=default

# === LLM (required for Dream Cycle and Memory Sync) ===
# GLM_API_KEY=***
# GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# DREAM_CYCLE_MODEL=glm-4-flash
# MEMORY_TO_WIKI_MODEL=glm-4-flash

# === Notion (optional, for wiki-to-notion sync) ===
# NOTION_API_KEY=***
# NOTION_DB_ENTITY=ntn_xxxxxxxx
# NOTION_DB_CONCEPT=ntn_xxxxxxxx
# NOTION_DB_COMPARISON=ntn_xxxxxxxx
# NOTION_DB_QUERY=ntn_xxxxxxxx

# === WebDAV / NAS (optional, for NAS sync) ===
# WEBDAV_BASE_URL=http://nas:5005/wiki
# WEBDAV_USER=***
# WEBDAV_PASS=***
