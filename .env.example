# ============================================================
# Wiki Brain — 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# ============================================================

# --- Wiki 路径 ---
WIKI_ROOT=/vol1/1000/wiki
MCP_PORT=8764
MCP_HOST=0.0.0.0

# --- OpenViking ---
OPENVIKING_ENDPOINT=http://REDACTED_IP:1933
OPENVIKING_API_KEY=
OPENVIKING_ACCOUNT=hermes
OPENVIKING_USER=default
# OPENVIKING_BIN=/usr/local/bin/openviking  # 可选，CLI binary 路径

# --- LLM (dream_cycle / memory_to_wiki) ---
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_API_KEY=
DREAM_CYCLE_MODEL=glm-4-flash
MEMORY_TO_WIKI_MODEL=glm-4-flash

# --- Notion (wiki-to-notion) ---
NOTION_API_KEY=
WEBDAV_BASE_URL=
WEBDAV_USER=
WEBDAV_PASS=

# --- 备份 ---
# WIKI_SOURCE=/vol1/1000/wiki
# WIKI_BACKUP_DIR=/vol1/1000/wiki-backups
# MAX_BACKUPS=10
