#!/bin/bash
# pre-push hook: lint check via docker exec
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

echo "🔍 Running pre-push checks..."

LINT_FAIL=0
for f in scripts/*.py; do
  if [[ -f "$f" ]]; then
    echo "  Checking $f..."
    if ! docker exec wiki-brain python3 -m py_compile "/app/scripts/$(basename $f)" 2>&1; then
      LINT_FAIL=1
    fi
  fi
done

if [[ $LINT_FAIL -eq 1 ]]; then
  echo "❌ Lint failed"
  exit 1
fi
echo "✅ Lint passed"
echo "✅ Pre-push checks passed"
