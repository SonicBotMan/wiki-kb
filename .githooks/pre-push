#!/bin/bash
# pre-push hook: run lint + tests before allowing push
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

echo "🔍 Running pre-push checks..."

export PYTHONPATH="$ROOT/scripts"

# Lint
python -m py_compile scripts/wiki_mcp_server.py && \
python -m py_compile scripts/wiki_utils.py && \
echo "✅ Lint passed" || { echo "❌ Lint failed"; exit 1; }

# Tests (only if pytest available)
if command -v pytest &>/dev/null; then
    pytest tests/ -v --tb=short || { echo "❌ Tests failed"; exit 1; }
else
    echo "⚠️  pytest not found, skipping tests"
fi

echo "✅ Pre-push checks passed"
